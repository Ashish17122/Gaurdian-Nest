{
  "expo": {
    "name": "GuardianNest",
    "slug": "guardiannest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "guardiannest",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.guardiannest",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Show monitoring status to your family",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },

    "android": {
      "package": "app.guardiannest",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#09637E"
      },
      "edgeToEdgeEnabled": true,

      "googleServicesFile": "./android/app/google-services.json",

      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "WAKE_LOCK",

        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",

        "PACKAGE_USAGE_STATS",
        "QUERY_ALL_PACKAGES"
      ]
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",


      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EBF4F6"
        }
      ],

      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#088395",
          "mode": "production"
        }
      ],

      "expo-font"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "0da41c15-390a-4442-930f-d905477b3d90"
      }
    },

    "owner": "ashishsharma007"
  }
}